{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LinearCue",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": true,
        "open": true
      },
      "window": {
        "all": true
      },
      "globalShortcut": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "https://api.groq.com/*",
          "https://generativelanguage.googleapis.com/*",
          "https://api.mistral.ai/*",
          "https://*.supabase.co/*"
        ]
      },
      "protocol": {
        "all": true,
        "asset": true,
        "assetScope": [
          "**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.linearcue.app",
      "icon": [
        "icons/icon.png"
      ],
      "externalBin": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "LinearCue",
        "width": 420,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/iamrahill7/linearcue/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyN0RDREZEMzNEQzQyRDQKUldUVVF0d3ovYzE5VW5lR0QxUWpXRGFrZWo0M2h4VkJUTWE0ajJteXJBYjdHZUgrVG55aG5CMzQK"
    }
  }
}